# LawCraft AI - Environment Configuration Example
# Copy this to .env.local and fill in your values

# ============================================
# Ollama AI Configuration
# ============================================

# Ollama server URL (where the AI model runs)
# Default: http://10.1.216.43:11434 (Friend's laptop)
VITE_OLLAMA_URL=http://10.1.216.43:11434

# Ollama model to use
# Options: llama3.1:7b, llama3.2:1b, llama2:7b, mistral:7b, etc.
# Default: llama3.1:7b
VITE_OLLAMA_MODEL=llama3.1:7b

# ============================================
# Supabase Configuration (Backend Database)
# ============================================

# Supabase Configuration
# Replace these with your actual Supabase project credentials
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# Firebase Configuration (Authentication)
# ============================================

# Add Firebase config if needed
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_PROJECT_ID=...

# ============================================
# Development Settings
# ============================================

# Node environment
NODE_ENV=development

# ============================================
# Optional: Advanced Settings
# ============================================

# API timeout in milliseconds (default: 30000)
# VITE_API_TIMEOUT=30000

# Enable debug logging (default: false)
# VITE_DEBUG=false
